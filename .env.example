# App runtime URL — prefer non-superuser hermes_app after bootstrap
# (see `bun run db:create-app-role`). Until then, local compose defaults work:
DATABASE_URL=postgres://hermes:hermes@localhost:5433/hermes
# After creating hermes_app:
# DATABASE_URL=postgres://hermes_app:<HERMES_APP_PASSWORD>@localhost:5433/hermes
#
# Privileged URL for migrations / role bootstrap / admin (bootstrap superuser).
# Keep this separate from DATABASE_URL once the app uses hermes_app.
# migrate currently reads DATABASE_URL — for schema changes either set
# DATABASE_URL to the admin URL, or:
#   DATABASE_URL=$DATABASE_ADMIN_URL bun run migrate
# DATABASE_ADMIN_URL=postgres://hermes:hermes@localhost:5433/hermes
#
# Password for `bun run db:create-app-role` (creates LOGIN NOSUPERUSER hermes_app).
# HERMES_APP_PASSWORD=
# Optional overrides: HERMES_APP_ROLE=hermes_app  HERMES_APP_DATABASE=hermes
#
# For remote/SSL: DATABASE_URL=postgres://user:pass@host:5432/hermes?sslmode=require
# sslmode values: disable | allow | prefer | require | verify-ca | verify-full
HERMES_DATA_DIR=C:/hermes-data
HERMES_BACKUP_DIR=C:/hermes-data/backups
# Number of backup dumps to keep (oldest pruned automatically)
HERMES_BACKUP_KEEP=10
# Bun.sql pool size (compose max_connections=50).
# Keep low: bun --hot reuses one pool (globalThis), but parallel processes add up.
# Default in code is 5; 4–5 is recommended for local multi-agent / test runs.
HERMES_DB_POOL_MAX=5
# Append-only event log retention (days). Prune with: bun run db:prune-events
HERMES_EVENT_RETENTION_DAYS=30
HERMES_MCP_EVENT_RETENTION_DAYS=30
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
# --- Capability Hub / staging rollout (see docs/CAPABILITIES-STAGING.md) ---
# Preferred tool-capable OpenAI-compatible base for /agui (MCP/A2UI/Cowork tool_calls).
# When unset and LLM_BASE_URL is the chat-only lm-bridge (:3456), agent tools degrade.
# Staging: set HERMES_AGENT_LLM_URL to a tool-capable endpoint (do not rely on :3456 alone).
# HERMES_AGENT_LLM_URL=https://api.openai.com/v1
# Optional dedicated embeddings endpoint (defaults to HERMES_AGENT_LLM_URL, then non-bridge LLM_BASE_URL).
# HERMES_EMBEDDINGS_URL=
# Operator rollback: legacy = regex tool subsetting + pre-LLM interceptors; capabilities = default hub.
# Staging default:
# HERMES_ROUTING=capabilities
# Bounded agent LLM health probe timeout (ms)
# HERMES_AGENT_LLM_TIMEOUT_MS=5000
# Dev-only: auto-start tools/lm-bridge (text chat, no tools) from `bun run dev`. Keep 0 in staging.
# HERMES_LM_BRIDGE=0
# Ops: GET /api/capabilities (?probe=1), POST /api/capabilities/warm, GET /api/debug/health (agentLlm)
# --- Default-on web search / fetch_url (require tool-capable HERMES_AGENT_LLM_URL; not lm-bridge alone) ---
# WEB_SEARCH_PROVIDER=auto|brave|tavily|serper|duckduckgo  (prefer tavily or brave in production)
# WEB_SEARCH_API_KEY=   # required for Brave/Tavily/Serper; DuckDuckGo works without a key (weaker)
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
LOG_LEVEL=debug
LOG_PRETTY=1
LOG_HTTP=1
DEBUG_LLM=1
# DEBUG_LLM_FULL=1
DEBUG_AGUI=1
DEBUG_DB=1
DEBUG_MCP=1
DEBUG_TOOLS=1
ALLOW_SIGNUP=false
AUTO_APPROVE_ALL=false
HOST=127.0.0.1
PORT=3001
WORKSPACE_ROOT=./workspace
# Jarvis fast indexer (Postgres-only recall; embeddings must be local via LLM_BASE_URL / HERMES_EMBEDDINGS_URL)
INDEXER_ENABLED=true
INDEXER_SCAN_ON_START=true
INDEXER_WATCHER_ENABLED=true
INDEXER_POLL_MS=15000
INDEXER_MAX_FILE_BYTES=524288
INDEXER_CHUNK_CHARS=1800
INDEXER_CHUNK_OVERLAP=200
INDEXER_CLAIM_LIMIT=16
INDEXER_CONCURRENCY=4
# Extra ignore segments (comma-separated), e.g. vendor,tmp,.venv
# INDEXER_EXCLUDE_GLOBS=
INDEXER_DEFAULT_TOP_K=8
INDEXER_PRUNE_DAYS=30
# Skills library root (SKILL.md folders). Point at legacy Hermes skills to import:
# SKILLS_DIR=C:/Users/dines/AppData/Local/hermes/skills
SKILLS_DIR=./skills

# Auth (generate: openssl rand -base64 32)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://127.0.0.1:3001

# =============================================================================
# (A) Microsoft Graph SSO — Office → Briefing / Sign in with Microsoft
# Independent of Open Cowork.exe. Chrome work-account cookies alone are NOT enough;
# you must register an Entra app and set CLIENT_ID + CLIENT_SECRET below.
# Setup helper: bun run office:sso-setup   (needs `az login`) or --manual
# Azure portal: Entra ID → App registrations → New → Authentication → Web
# Redirect URI (exact match required):
#   http://127.0.0.1:3001/api/office/callback
# API permissions (delegated): User.Read, Calendars.Read, OnlineMeetings.Read (+ offline_access)
# Optional later (admin consent): OnlineMeetingArtifact.Read.All, OnlineMeetingTranscript.Read.All
# Docs: https://learn.microsoft.com/en-us/entra/identity-platform/v2-oauth2-auth-code-flow
#       https://learn.microsoft.com/en-us/graph/api/user-list-calendarview
# After setting values: restart the API, open Office → Briefing (or /login), click
# "Sign in with Microsoft" in the SAME Chrome profile that has your work account.
# =============================================================================
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=organizations
# Auto-redirect Office Briefing to Microsoft SSO when not connected
MICROSOFT_SSO_AUTO=true
# MICROSOFT_REDIRECT_URI=http://127.0.0.1:3001/api/office/callback

# Model context window shown in the footer (tokens)
CONTEXT_TOKEN_LIMIT=128000
# Max estimated tokens injected for memory + skills per run
CONTEXT_INJECTION_BUDGET=8000

# Background cleanup worker (prunes old run_events, archived sessions, run buffer, sandbox temp files)
CLEANUP_ENABLED=true
CLEANUP_INTERVAL_MS=3600000
CLEANUP_RUN_EVENT_RETENTION_DAYS=7
CLEANUP_ARCHIVED_SESSION_RETENTION_DAYS=30
CLEANUP_SANDBOX_RETENTION_MINUTES=60

# Set to 1 to run DB integration tests (truncates app tables on localhost:5433 only)
HERMES_INTEGRATION_TEST=0

# Set to 1 (or LLM_API_KEY=mock) for scripted AG-UI runs without a real LLM key
HERMES_MOCK_LLM=0
# Mock scenario: a2ui-cron | a2ui-memory | a2ui-skills (or embed in user message)
# HERMES_MOCK_SCENARIO=a2ui-cron

# =============================================================================
# (B) Open Cowork — optional local document jobs (NOT Microsoft SSO)
# Requires the installed Open Cowork desktop binary — not the docs tree under BMC/center/open-cowork.
# SSO for Office email/calendar does not use this path.
# Download: https://github.com/OpenCoworkAI/open-cowork/releases
# Windows installer (v3.3.1): https://github.com/OpenCoworkAI/open-cowork/releases/download/v3.3.1/Open.Cowork-3.3.1-win-x64.exe
# Typical install path (note the space in "Open Cowork"):
# OPEN_COWORK_EXE=C:/Users/You/AppData/Local/Programs/Open Cowork/Open Cowork.exe
# Aliases: OPEN_COWORK_PATH or COWORK_EXE (same meaning).
# Or paste the path in Cowork → Setup (persists as settings cowork.exe; no restart).
# OPEN_COWORK_WORKSPACE=C:/Users/You/cowork-workspace
# OPEN_COWORK_AUTO_APPROVE=true
# OPEN_COWORK_TIMEOUT_MS=900000
# Optional live smoke: OPEN_COWORK_LIVE=1 with a real OPEN_COWORK_EXE.
# =============================================================================

# --- Debuggable logs (Open Jarvis) ---
# LOG_LEVEL=debug|info|warn|error
# LOG_PRETTY=1 human lines; LOG_JSON=1 force JSON
# LOG_HTTP / DEBUG_HTTP — every request
# DEBUG_LLM / DEBUG_LLM_FULL — LLM summaries / full payloads (secrets redacted)
# DEBUG_AGUI — run lifecycle + event types
# DEBUG_DB / DEBUG_MCP / DEBUG_TOOLS — subsystem traces
