[Unit]
Description=Open Jarvis (Hermes UI + AG-UI server)
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=hermes
Group=hermes
WorkingDirectory=/opt/open-jarvis
EnvironmentFile=/opt/open-jarvis/.env
ExecStart=/home/hermes/.bun/bin/bun run /opt/open-jarvis/scripts/start-production.ts
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
