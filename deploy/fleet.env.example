# =============================================================================
# Fleet-wide — identical on every host (GPO / SCCM / Ansible group_vars)
# Merge with deploy/host.env on each machine at install time.
# =============================================================================

ALLOW_SIGNUP=false
HERMES_ALLOW_DB_PATH_SETTINGS=0
HERMES_SERVE_STATIC=1
LOG_LEVEL=info
LOG_PRETTY=0

# LDAP app login (same directory for all Jarvis hosts)
LDAP_ENABLED=1
LDAP_URL=ldap://dc.corp.example.com:389
LDAP_BIND_DN=CN=svc-hermes,OU=Service Accounts,DC=corp,DC=example,DC=com
LDAP_BIND_PASSWORD=__FROM_VAULT__
LDAP_BASE_DN=DC=corp,DC=example,DC=com
LDAP_USER_ATTRIBUTE=sAMAccountName
LDAP_EMAIL_DOMAIN=corp.example.com
LDAP_TIMEOUT_MS=8000
LDAP_TLS_REJECT_UNAUTHORIZED=1

# LLM — corporate gateway, tool-capable (required for web_search / agent tools)
LLM_BASE_URL=https://llm-gw.corp.example.com/v1
HERMES_AGENT_LLM_URL=https://llm-gw.corp.example.com/v1
LLM_API_KEY=__FROM_VAULT__

# Web search — DuckDuckGo is keyless default; set a key for production quality
WEB_SEARCH_PROVIDER=auto
# Google results (recommended): serper.dev (fastest) or official Google CSE
# WEB_SEARCH_PROVIDER=serper
# WEB_SEARCH_API_KEY=__FROM_VAULT__
# WEB_SEARCH_PROVIDER=google
# WEB_SEARCH_GOOGLE_CX=__ENGINE_ID__

# BETTER_AUTH_SECRET is per-host — set in host.env (generated at install)
