# =============================================================================
# Per-host — templated at install (hostname, data dir, secrets)
# =============================================================================

# Only variable that MUST differ per machine (paths derive from here)
HERMES_DATA_DIR=C:/hermes-data

# Listen on all interfaces in production
HOST=0.0.0.0
PORT=3001

# Public URL for this machine (cookies + CORS + LDAP redirect)
# Replace {{HOST_FQDN}} with machine FQDN, e.g. jarvis-042.corp.example.com
BETTER_AUTH_URL=https://{{HOST_FQDN}}:3001
HERMES_PUBLIC_URL=https://{{HOST_FQDN}}:3001

# Generated once per host: openssl rand -base64 32
BETTER_AUTH_SECRET={{GENERATE_AT_INSTALL}}

# Local Postgres (docker compose on same host)
DATABASE_URL=postgres://hermes:hermes@localhost:5433/hermes

# Optional: reverse-proxy front door shared across fleet
# CORS_ORIGINS=https://jarvis.corp.example.com
